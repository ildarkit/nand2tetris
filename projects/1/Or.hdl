// File name: projects/1/Or.hdl
/**
 * Or gate:
 * if (a or b) out = 1, else out = 0 
 */
CHIP Or {
    IN a, b;
    OUT out;

    PARTS:
    And(a=a, b=true, out=outA);
    And(a=true, b=b, out=outB);
    Not(in=outA, out=outNotA);
    Not(in=outB, out=outNotB);
    And(a=outNotA, b=outNotB, out=outAnd);
    Not(in=outAnd, out=out);
}
